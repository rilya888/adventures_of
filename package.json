{
  "name": "adventures-of",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "deploy": "npx -y @railway/cli up --detach --no-gitignore",
    "deploy:web": "npx -y @railway/cli up --detach --no-gitignore -s web",
    "deploy:worker": "npx -y @railway/cli up --detach --no-gitignore -s worker",
    "deploy:all": "npm run deploy:web && npm run deploy:worker",
    "start": "next start",
    "worker": "tsx src/worker/index.ts",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@tanstack/react-query": "^5.90.21",
    "next": "16.1.6",
    "openai": "^6.25.0",
    "pg": "^8.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "replicate": "^1.4.0",
    "stripe": "^17.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
